---
import { getCollection } from 'astro:content';

const CATEGORIES = [
  { slug: 'cloud-architecture',   label: 'Cloud Architecture',   theme: 'fjord' },
  { slug: 'legacy-systems',       label: 'Legacy Systems',       theme: 'foundry' },
  { slug: 'geospatial',           label: 'Geospatial & Maps',    theme: 'fjord' },
  { slug: 'engineering-culture',  label: 'Engineering Culture',  theme: 'midnight' },
  { slug: 'family-legacy',        label: 'Family Legacy',        theme: 'foundry' },
  { slug: 'ai-strategy',          label: 'AI Strategy',          theme: 'midnight' },
] as const;

// Count posts per category by matching tags
const allPosts = await getCollection('posts', ({ data }) =>
  data.status === 'published' || data.status === 'scheduled'
);

function countForCategory(slug: string): number {
  const keyword = slug.replace(/-/g, ' ');
  return allPosts.filter((p) =>
    (p.data.tags ?? []).some((t) => t.toLowerCase().includes(keyword) || keyword.includes(t.toLowerCase()))
  ).length;
}
---

<!-- Full-screen overlay menu -->
<div id="category-menu" class="cat-menu" aria-hidden="true" role="dialog" aria-label="Topics menu">
  <button class="cat-close" data-menu-close type="button" aria-label="Close menu">✕</button>

  <div class="cat-inner">
    <p class="cat-heading">TOPICS</p>
    <ul class="cat-list">
      {CATEGORIES.map((cat) => (
        <li class="cat-item" data-cat-theme={cat.theme}>
          <a href={`/posts/?category=${cat.slug}`} class="cat-link">
            <span class="cat-label">{cat.label}</span>
            <span class="cat-count">[{countForCategory(cat.slug)}]</span>
          </a>
        </li>
      ))}
    </ul>
    <a href="/posts/" class="cat-all">View all articles →</a>
  </div>
</div>

<style>
  .cat-menu {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    background: rgba(4, 10, 22, 0.94);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 320ms ease, visibility 320ms ease;
  }

  .cat-menu.is-open {
    opacity: 1;
    visibility: visible;
  }

  .cat-close {
    position: absolute;
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
    background: none;
    border: 1px solid rgba(200, 220, 255, 0.15);
    color: #d0e2ff;
    font-size: 1.2rem;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .cat-close:hover {
    border-color: var(--accent, #4da3ff);
    transform: rotate(90deg);
  }

  .cat-inner {
    padding-left: clamp(2rem, 8vw, 6rem);
    max-width: 640px;
  }

  .cat-heading {
    margin: 0 0 1.5rem;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: rgba(200, 220, 255, 0.5);
    text-transform: uppercase;
  }

  .cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.4rem;
  }

  .cat-item {
    opacity: 0;
    transform: translateY(18px);
  }

  .cat-menu.is-open .cat-item {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 400ms ease, transform 400ms ease;
  }

  /* Stagger reveal */
  .cat-item:nth-child(1) { transition-delay: 60ms; }
  .cat-item:nth-child(2) { transition-delay: 120ms; }
  .cat-item:nth-child(3) { transition-delay: 180ms; }
  .cat-item:nth-child(4) { transition-delay: 240ms; }
  .cat-item:nth-child(5) { transition-delay: 300ms; }
  .cat-item:nth-child(6) { transition-delay: 360ms; }

  .cat-link {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    text-decoration: none;
    padding: 0.5rem 0;
    transition: color 180ms ease;
  }

  .cat-label {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #e0ecff;
    transition: color 180ms ease;
  }

  .cat-link:hover .cat-label {
    color: var(--accent, #4da3ff);
  }

  .cat-count {
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.78rem;
    color: rgba(200, 220, 255, 0.4);
    letter-spacing: 0.04em;
  }

  .cat-all {
    display: inline-block;
    margin-top: 2rem;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.78rem;
    color: rgba(200, 220, 255, 0.5);
    text-decoration: none;
    letter-spacing: 0.06em;
    transition: color 180ms ease;
  }

  .cat-all:hover {
    color: var(--accent, #4da3ff);
  }
</style>

<script>
  const menu     = document.getElementById('category-menu')!;
  const openBtn  = document.querySelector<HTMLElement>('[data-menu-btn]');
  const closeBtn = document.querySelector<HTMLElement>('[data-menu-close]');

  const open = () => {
    menu.classList.add('is-open');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const close = () => {
    menu.classList.remove('is-open');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  openBtn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu.classList.contains('is-open')) close();
  });

  // Close when clicking backdrop (not inner content)
  menu.addEventListener('click', (e) => {
    if (e.target === menu) close();
  });
</script>
