---
// ThemeToggle — cycles Fjord -> Foundry -> Midnight and persists to localStorage
---

<button
  id="theme-toggle"
  class="lab-toggle theme-toggle"
  type="button"
  aria-label="Theme: Fjord. Click to change."
  title="Cycle Lab Themes"
>
  <span class="cheese-icon" aria-hidden="true">
    <!-- Cheese Curd: lumpy irregular nugget with holes -->
    <svg class="cheese-curd" viewBox="0 0 32 32" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M8 26c-3-1.5-5-5-4.5-9 .4-3.2 2-5.6 4-7.5C9.5 7.5 12 6 15 5.5c2.8-.5 5.5 0 7.8 1.2 2.8 1.5 4.7 4 5.2 7 .6 3.5-.5 6.8-2.8 9-2 1.8-4.5 3.2-7.2 3.8-3.5.8-7-.2-10-1.5z" fill="#F5C518"/>
      <path d="M8 26c-3-1.5-5-5-4.5-9 .4-3.2 2-5.6 4-7.5C9.5 7.5 12 6 15 5.5c2.8-.5 5.5 0 7.8 1.2 2.8 1.5 4.7 4 5.2 7 .6 3.5-.5 6.8-2.8 9-2 1.8-4.5 3.2-7.2 3.8-3.5.8-7-.2-10-1.5z" fill="url(#curdGrad)"/>
      <ellipse cx="12" cy="14" rx="2.2" ry="1.8" fill="#E0A800" opacity="0.7"/>
      <ellipse cx="20" cy="18" rx="1.6" ry="1.4" fill="#E0A800" opacity="0.6"/>
      <ellipse cx="17" cy="11" rx="1.1" ry="0.9" fill="#D4960A" opacity="0.5"/>
      <path d="M8 26c-3-1.5-5-5-4.5-9 .4-3.2 2-5.6 4-7.5C9.5 7.5 12 6 15 5.5c2.8-.5 5.5 0 7.8 1.2 2.8 1.5 4.7 4 5.2 7 .6 3.5-.5 6.8-2.8 9-2 1.8-4.5 3.2-7.2 3.8-3.5.8-7-.2-10-1.5z" stroke="#C8920A" stroke-width="0.8" fill="none"/>
      <defs>
        <radialGradient id="curdGrad" cx="0.35" cy="0.3" r="0.7">
          <stop offset="0%" stop-color="#FFE066"/>
          <stop offset="70%" stop-color="#F5C518"/>
          <stop offset="100%" stop-color="#D4960A"/>
        </radialGradient>
      </defs>
    </svg>
    <!-- Cheese Ball: smooth round sphere with speckled coating -->
    <svg class="cheese-ball" viewBox="0 0 32 32" width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="16" cy="16" r="12" fill="#E88A1A"/>
      <circle cx="16" cy="16" r="12" fill="url(#ballGrad)"/>
      <circle cx="12" cy="12" r="1.3" fill="#FFB847" opacity="0.6"/>
      <circle cx="20" cy="14" r="0.9" fill="#FFB847" opacity="0.5"/>
      <circle cx="14" cy="20" r="1.0" fill="#D07010" opacity="0.4"/>
      <circle cx="19" cy="21" r="0.7" fill="#FFB847" opacity="0.35"/>
      <circle cx="10" cy="17" r="0.6" fill="#D07010" opacity="0.3"/>
      <circle cx="22" cy="11" r="0.5" fill="#FFB847" opacity="0.4"/>
      <circle cx="16" cy="16" r="12" stroke="#B86008" stroke-width="0.7" fill="none"/>
      <!-- highlight -->
      <ellipse cx="12.5" cy="10" rx="4" ry="2.8" fill="white" opacity="0.18" transform="rotate(-25 12.5 10)"/>
      <defs>
        <radialGradient id="ballGrad" cx="0.38" cy="0.32" r="0.65">
          <stop offset="0%" stop-color="#FFAD3B"/>
          <stop offset="60%" stop-color="#E88A1A"/>
          <stop offset="100%" stop-color="#C06A08"/>
        </radialGradient>
      </defs>
    </svg>
  </span>
</button>

<style>
  .cheese-icon {
    width: 22px;
    height: 22px;
    position: relative;
    display: inline-grid;
    place-items: center;
  }

  .cheese-curd,
  .cheese-ball {
    position: absolute;
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .cheese-curd {
    opacity: 1;
    transform: scale(1);
  }

  .cheese-ball {
    opacity: 0;
    transform: scale(0.72);
  }

  .theme-toggle[data-cheese='ball'] .cheese-curd {
    opacity: 0;
    transform: scale(0.7);
  }

  .theme-toggle[data-cheese='ball'] .cheese-ball {
    opacity: 1;
    transform: scale(1);
  }
</style>

<script>
  const THEMES = ['fjord', 'foundry', 'midnight'] as const;
  type Theme = typeof THEMES[number];

  const LABELS: Record<Theme, string> = {
    fjord:    'Fjord',
    foundry:  'Foundry',
    midnight: 'Midnight'
  };

  function isTheme(v: string | null): v is Theme {
    return THEMES.includes(v as Theme);
  }

  const btn = document.getElementById('theme-toggle')!;

  function syncCheese(theme: Theme) {
    const cheese = theme === 'fjord' ? 'curd' : 'ball';
    btn.setAttribute('data-cheese', cheese);
  }

  function applyTheme(next: Theme) {
    document.body.classList.remove('theme-wave-active');
    void document.body.offsetWidth;
    document.body.classList.add('theme-wave-active');

    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    btn.setAttribute('aria-label', `Theme: ${LABELS[next]}. Click to change.`);
    syncCheese(next);
    window.dispatchEvent(new CustomEvent('lab-theme-change', { detail: { theme: next } }));
  }

  btn.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const idx     = isTheme(current) ? THEMES.indexOf(current) : 0;
    const next    = THEMES[(idx + 1) % THEMES.length];
    applyTheme(next);
  });

  // Sync initial aria-label
  const initial = document.documentElement.getAttribute('data-theme');
  if (isTheme(initial)) {
    btn.setAttribute('aria-label', `Theme: ${LABELS[initial]}. Click to change.`);
    syncCheese(initial);
  } else {
    syncCheese('fjord');
  }

  document.body.addEventListener('animationend', (event) => {
    if (event.animationName === 'theme-wave') {
      document.body.classList.remove('theme-wave-active');
    }
  });
</script>
