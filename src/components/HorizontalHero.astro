---
interface Card {
  title: string;
  description: string;
  href: string;
}

interface Props {
  img_farm: string;
  img_oslo: string;
  voyage?: string[];
  cards?: Card[];
}

const { img_farm, img_oslo, voyage = [], cards = [] } = Astro.props;

const displayCards = cards.length
  ? cards.slice(0, 3)
  : [
      { title: 'Architecting AI in the Loop', description: 'Shipping AI with guardrails.', href: '/posts/' },
      { title: 'Resilient Cloud Decision Trees', description: 'Tradeoffs that survive Friday night.', href: '/posts/' },
      { title: 'Signal over Hype Patterns', description: 'Proven Azure delivery patterns.', href: '/posts/' },
    ];
---

<div class="montage" data-story-root>
  <!-- ═══ Fixed cinematic image stage ════════════════════════════ -->
  <div class="stage" data-stage>
    <!-- Farm: focus on barn center-left -->
    <picture class="layer-pic layer-farm">
      <img class="layer story-image" src={img_farm} alt="Wisconsin farm landscape" width="1600" height="900" loading="eager" decoding="async" style="object-position: 50% 50%" />
    </picture>
    <!-- Voyage images: each with contextual focus -->
    {voyage.map((src, i) => {
      const positions = ['50% 50%', '50% 50%', '50% 50%', '50% 50%', '50% 50%'];
      return (
        <picture class={`layer-pic layer-voyage layer-v${i}`}>
          <img class="layer story-image" src={src} alt={`Voyage era ${i + 1}`} width="1600" height="900" loading="lazy" decoding="async" style={`object-position: ${positions[i] || '50% 50%'}`} />
        </picture>
      );
    })}
    <!-- Oslo: focus on skyline at bottom -->
    <picture class="layer-pic layer-oslo">
      <img class="layer story-image" src={img_oslo} alt="Oslo skyline" width="1600" height="900" loading="lazy" decoding="async" style="object-position: 50% 100%" />
    </picture>
    <div class="fog"></div>
    <div class="grain"></div>
    <div class="vignette"></div>
    <div class="grid-overlay"></div>
  </div>

  <!-- ═══ Mapbox globe canvas (hidden until panel 4) ═════════════ -->
  <div class="globe-stage" data-globe-stage>
    <div id="mapbox-globe" data-globe-el></div>
    <div class="radar-grid" aria-hidden="true"></div>
  </div>

  <!-- ═══ Progress rail ══════════════════════════════════════════ -->
  <div class="rail" aria-hidden="true"><div class="rail-fill" data-rail></div></div>

  <!-- ═══ Coordinate readout ═════════════════════════════════════ -->
  <div class="coord-badge" aria-live="polite">
    <span class="coord-label">POS</span>
    <span class="coord-value" data-coord>45.3° N, 91.8° W</span>
  </div>

  <!-- ── Panel 1: Wisconsin Farm ─────────────────────────────── -->
  <section id="about" class="panel story-section">
    <div class="story-content">
    <div class="tray tray-left">
      <p class="kicker">ABOUT ME · NORTHERN WISCONSIN · 45.3° N</p>
      <h2>Northern<br/>Roots.</h2>
      <p class="copy">I was born in Northern Wisconsin. I met the love of my life, moved to Norway, and started over with about $1,000 and a long-horizon mindset.</p>
      <p class="cue" aria-hidden="true">SCROLL DOWN ↓</p>
    </div>
    </div>
  </section>

  <!-- ── Panel 2: The Voyage ─────────────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-right">
      <p class="kicker">THE CROSSING · WISCONSIN → NORWAY</p>
      <h2>The<br/>Crossing.</h2>
      <p class="copy">From lake country to fjord country, this is the bridge between where I started and where I build today. Different landscape, same values: resilience, discipline, and practical execution.</p>
    </div>
    </div>
  </section>

  <!-- ── Panel 3: Oslo ───────────────────────────────────────── -->
  <section id="lab" class="panel story-section">
    <div class="story-content">
    <div class="tray tray-left">
      <p class="kicker">ABOUT THE LAB · OSLO REGION · 59.9° N</p>
      <h2>Signal Over<br/>Hype Lab.</h2>
      <p class="copy">I work for Microsoft and I am building a home outside Oslo. The Lab is where field lessons become clear architecture patterns you can explain and operate when the pressure is on.</p>

      <div class="cards">
        {displayCards.map((card) => (
          <a class="card" href={card.href}>
            <p class="card-eye">TECHNICAL SCHEMATIC</p>
            <h3>{card.title}</h3>
            <p class="card-desc">{card.description}</p>
            <div class="card-ledger">
              <p>Region: Norway East (Oslo)</p>
              <p>Origin: US North Central (WI)</p>
              <p>Status: Deployed</p>
              <p>Provider: Azure</p>
            </div>
          </a>
        ))}
      </div>
    </div>
    </div>
  </section>

  <!-- ── Panel 4: Mapbox Globe Flyover ───────────────────────── -->
  <section class="panel story-section globe-panel">
    <div class="story-content">
    <div class="tray tray-left tray-globe">
      <p class="kicker">THE FLYOVER · SATELLITE VIEW</p>
      <h2>Mapping<br/>The Signal.</h2>
      <p class="copy">45.3° N, 91.8° W → 59.9° N, 10.7° E</p>
    </div>
    </div>
  </section>
</div>

<style>
  .montage { position: relative; width: 100%; background: #000; }

  .story-section {
    width: 100vw;
    height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .story-content {
    width: 100%;
    display: flex;
    align-items: center;
  }

  /* ═══ Fixed image stage ════════════════════════════════════════ */
  .stage { position: fixed; inset: 0; overflow: hidden; z-index: 1; }

  .layer-pic {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    overflow: hidden;
  }

  .layer {
    display: block;
    width: 100%; height: 100%;
    object-fit: cover;
    background: #000;
    will-change: opacity, transform;
    /* Keep motion subtle so low-res assets do not look artificially zoomed */
    animation: slow-pan 28s infinite alternate ease-in-out;
  }

  .story-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes slow-pan {
    from { transform: scale(1); }
    to   { transform: scale(1.001); }
  }

  .fog {
    position: absolute;
    inset: -8%;
    pointer-events: none;
    z-index: 2;
    background:
      radial-gradient(ellipse 70% 55% at center, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 24%, rgba(8,16,28,0.22) 62%, rgba(2,6,12,0.45) 100%),
      radial-gradient(ellipse 90% 75% at 50% 60%, rgba(130,170,210,0.14) 0%, rgba(10,18,30,0.04) 48%, transparent 70%);
    filter: blur(20px);
    opacity: 0.62;
  }

  .layer-farm { opacity: 1; }
  .layer-farm .layer { filter: brightness(0.5) sepia(0.18) saturate(0.9); }
  .layer-voyage { opacity: 0; }
  .layer-voyage {
    /* 25% visual size: 37.5% inset on each side */
    inset: 37.5%;
  }
  .layer-voyage .layer {
    object-fit: contain;
    object-position: 50% 50%;
    filter: brightness(0.48) sepia(0.28) saturate(0.78);
  }
  .layer-oslo { opacity: 0; }
  .layer-oslo .layer { filter: brightness(0.5); }

  /* Mobile: shift focus points for portrait screens (9:16) */
  @media (max-aspect-ratio: 3/4) {
    /* Z-AXIS DEPTH: subject in middle 40%, sky top 30%, text bottom 30% */

    /* Farm: focus tight on barn, let fields fall away */
    .layer-farm .layer  { object-position: 50% 50%; }

    /* Ship layers: imposing, heading toward top of screen */
    .layer-voyage {
      inset: 37.5%;
    }
    .layer-v0 .layer { object-position: 50% 50%; } /* Colonial ship */
    .layer-v1 .layer { object-position: 50% 50%; } /* Warship sketch */
    .layer-v2 .layer { object-position: 50% 50%; } /* Clipper */
    .layer-v3 .layer { object-position: 50% 50%; } /* Steamship */
    .layer-v4 .layer { object-position: 50% 50%; } /* SAS 737 */

    /* Oslo: architecture weighted to bottom, sky fills top */
    .layer-oslo .layer { object-position: 50% 100%; }

    /* Heavier "Montfort Mist" for text contrast on mobile */
    .vignette {
      background:
        linear-gradient(180deg, rgba(0,0,0,0.25) 0%, transparent 35%, transparent 55%, rgba(0,0,0,0.6) 100%),
        radial-gradient(ellipse 80% 80% at center, transparent 15%, rgba(0,0,0,0.72) 100%);
    }

    .grain { opacity: 0.38; }
    .fog { opacity: 0.64; }

    /* Text trays: anchor to bottom 30% of viewport */
    .panel { align-items: flex-end; padding-bottom: env(safe-area-inset-bottom, 1.5rem); }
    .tray { margin-bottom: clamp(1rem, 4vh, 2.5rem); max-width: 100%; }
    .tray-left, .tray-right { margin-left: 0.75rem; margin-right: 0.75rem; }
  }

  .grain {
    position: absolute; inset: 0; opacity: 0.12;
    mix-blend-mode: overlay; pointer-events: none;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.82' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-size: 200px;
  }

  .vignette {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse 72% 70% at center, transparent 36%, rgba(0,0,0,0.54) 100%);
  }

  .grid-overlay {
    display: none;
    position: absolute; inset: 0; pointer-events: none; opacity: 0;
    background-image: radial-gradient(circle, rgba(77,163,255,0.16) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  /* ═══ Mapbox globe stage ═══════════════════════════════════════ */
  .globe-stage {
    position: fixed; inset: 0; z-index: 1;
      opacity: 0; pointer-events: none;
  }

  .globe-stage.is-active {
      pointer-events: auto;
  }

  #mapbox-globe {
    width: 100%; height: 100%;
  }

  .radar-grid {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      radial-gradient(circle, rgba(77,163,255,0.08) 1px, transparent 1px),
      repeating-conic-gradient(from 0deg, rgba(77,163,255,0.04) 0deg 1deg, transparent 1deg 30deg);
    background-size: 40px 40px, 100% 100%;
    opacity: 0.5;
  }

  /* ═══ Panels ══════════════════════════════════════════════════ */
  .panel {
    height: 100vh; position: relative; z-index: 2;
    display: flex; align-items: center;
    color: #f0f4ff;
  }

  .tray {
    max-width: 720px;
    padding: clamp(1rem, 2.2vw, 1.8rem) clamp(1rem, 2.2vw, 1.6rem);
    background: linear-gradient(90deg, rgba(8,14,24,0.34), rgba(8,14,24,0.08) 72%, transparent);
    border-left: 2px solid rgba(212,225,242,0.45);
    border-radius: 0;
    box-shadow: none;
    position: relative; z-index: 3;
  }

  /* Off-axis layouts — Mont-Fort style */
  .tray-left { margin-left: clamp(2rem,6vw,5rem); }
  .tray-right { margin-left: auto; margin-right: clamp(2rem,6vw,5rem); }

  .tray-globe { margin-bottom: auto; margin-top: clamp(4rem,12vh,8rem); }

  .kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.7rem; letter-spacing: 0.14em;
    text-transform: uppercase; opacity: 0.75;
  }

  .panel h2 {
    margin: 0; font-family: var(--font-display);
    font-size: clamp(2.1rem, 6.2vw, 6.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 0.95;
    text-transform: none;
  }

  .copy {
    margin: 1.1rem 0 0;
    max-width: 54ch;
    font-size: clamp(0.98rem, 1.2vw, 1.16rem);
    line-height: 1.68;
    color: rgba(231,238,248,0.92);
  }
  .cue { margin-top: 2rem; font-family: var(--font-mono, Consolas, monospace); font-size: 0.76rem; letter-spacing: 0.14em; opacity: 0.55; }

  /* ═══ Progress rail ═══════════════════════════════════════════ */
  .rail { position: fixed; left: 0; top: 0; width: 3px; height: 100vh; z-index: 60; background: rgba(120,150,180,0.1); pointer-events: none; }
  .rail-fill { width: 100%; height: 0%; background: var(--accent, #ff6b35); box-shadow: 0 0 8px var(--accent, #ff6b35); transition: height 80ms linear; }

  /* ═══ Coord badge ═════════════════════════════════════════════ */
  .coord-badge {
    position: fixed; right: clamp(0.8rem,2vw,1.6rem); bottom: clamp(0.8rem,2vw,1.4rem);
    z-index: 60; display: flex; gap: 0.5rem; align-items: baseline;
    padding: 0.35rem 0.65rem; border-radius: 10px;
    border: 1px solid rgba(200,220,255,0.12);
    background: rgba(6,14,28,0.72);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    color: #d0e2ff; font-family: var(--font-mono, Consolas, monospace); pointer-events: none;
  }
  .coord-label { font-size: 0.62rem; letter-spacing: 0.14em; opacity: 0.65; }
  .coord-value { font-size: 0.82rem; font-weight: 600; font-variant-numeric: tabular-nums; }

  /* ═══ Cards ═══════════════════════════════════════════════════ */
  .cards { margin-top: 1.5rem; display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
  .card {
    text-decoration: none;
    color: #e6efff;
    border-radius: 0;
    border: 0;
    border-top: 1px solid rgba(196,214,236,0.24);
    background: transparent;
    padding: 0.9rem 0.1rem;
    transition: transform 180ms ease, border-color 180ms ease;
  }
  .card:hover { transform: translateX(4px); border-color: rgba(227,237,249,0.58); }
  .card-eye { margin: 0; font-family: var(--font-mono, Consolas, monospace); font-size: 0.66rem; letter-spacing: 0.06em; opacity: 0.72; }
  .card h3 { margin: 0.4rem 0; font-family: var(--font-display); font-size: 1rem; line-height: 1.3; }
  .card-desc { margin: 0; font-size: 0.9rem; color: #c6d5ea; line-height: 1.55; }
  .card-ledger { margin-top: 0.5rem; padding-top: 0.45rem; border-top: 0; }
  .card-ledger p { margin: 0; font-family: var(--font-mono, Consolas, monospace); font-size: 0.66rem; letter-spacing: 0.05em; line-height: 1.55; opacity: 0.78; }

  /* ═══ Theme tinting ═══════════════════════════════════════════ */
  html[data-theme='foundry'] .layer-farm .layer,
  html[data-theme='foundry'] .layer-voyage .layer { filter: brightness(0.42) sepia(0.45) saturate(1.0) hue-rotate(-12deg); }
  html[data-theme='fjord'] .layer-oslo .layer { filter: brightness(0.52) saturate(1.1) hue-rotate(-8deg); }
  html[data-theme='midnight'] .layer { filter: brightness(0.38) grayscale(1) contrast(1.22); }

  @media (max-width: 980px) {
    .tray-left, .tray-right { margin-left: 1rem; margin-right: 1rem; max-width: 100%; }
    .panel h2 { font-size: clamp(2rem, 10vw, 4rem); }
    .kicker { font-size: 0.62rem; }
    .copy { font-size: 0.95rem; }
    .coord-badge { bottom: auto; top: clamp(0.5rem, 2vw, 1rem); right: clamp(0.5rem, 2vw, 1rem); }
  }

  @media (max-width: 768px) {
    .story-section {
      height: 100svh;
    }
  }

  @media (max-width: 480px) {
    .tray { padding: 1rem; border-radius: 16px; }
    .panel h2 { font-size: clamp(1.6rem, 12vw, 2.4rem); }
    .cards { gap: 0.5rem; }
    .card { padding: 0.7rem; }
    .card h3 { font-size: 0.9rem; }
    .rail { width: 2px; }
    .layer { animation-duration: 30s; } /* Slower on mobile */
  }

  /* Large / ultrawide screens */
  @media (min-width: 1600px) {
    .tray { max-width: 640px; padding: 2.5rem; }
    .copy { font-size: 1.25rem; max-width: 52ch; }
    .tray-left { margin-left: clamp(4rem, 8vw, 10rem); }
    .tray-right { margin-right: clamp(4rem, 8vw, 10rem); }
  }

  @media (min-width: 2400px) {
    .tray { max-width: 780px; }
    .panel h2 { font-size: 7rem; }
  }

  @media (min-width: 2000px) {
    .story-content {
      max-width: min(1280px, calc(100vw - 4rem));
      margin-inline: auto;
    }
    .tray-left,
    .tray-right {
      margin-left: 0;
      margin-right: 0;
    }
    .tray-right {
      margin-left: auto;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .layer, .grain, .vignette, .grid-overlay, .globe-stage { transition: none !important; animation: none !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';
  gsap.registerPlugin(ScrollTrigger);

  // ── ① Lenis virtual scroll — single RAF source, premium-heavy feel ──
  // Feed Lenis delta into GSAP's own ticker so there is exactly one RAF loop.
  // Do NOT call requestAnimationFrame anywhere else in this file.
  const lenis = new Lenis({ lerp: 0.1, syncTouch: false });
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);
  // Sync Lenis scroll events → ScrollTrigger position reads
  lenis.on('scroll', () => ScrollTrigger.update());
  // After GSAP pin extends document height, tell Lenis the new scroll range
  ScrollTrigger.addEventListener('refresh', () => lenis.resize());

  const root       = document.querySelector<HTMLElement>('[data-story-root]');
  const stage      = document.querySelector<HTMLElement>('[data-stage]');
  const globeStage = document.querySelector<HTMLElement>('[data-globe-stage]');
  const globeEl    = document.querySelector<HTMLElement>('[data-globe-el]');
  const farm       = document.querySelector<HTMLElement>('.layer-farm');
  const voyages    = Array.from(document.querySelectorAll<HTMLElement>('.layer-voyage'));
  const oslo       = document.querySelector<HTMLElement>('.layer-oslo');
  const grain      = document.querySelector<HTMLElement>('.grain');
  const vig        = document.querySelector<HTMLElement>('.vignette');
  const grid       = document.querySelector<HTMLElement>('.grid-overlay');
  const coordEl    = document.querySelector<HTMLElement>('[data-coord]');
  const railEl     = document.querySelector<HTMLElement>('[data-rail]');

  // ── Diagnostic image swap ─────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const useDiagImages = params.get('diagImages') === '1';

  if (useDiagImages) {
    const farmImg    = document.querySelector<HTMLImageElement>('.layer-farm .layer');
    const osloImg    = document.querySelector<HTMLImageElement>('.layer-oslo .layer');
    const voyageImgs = Array.from(document.querySelectorAll<HTMLImageElement>('.layer-voyage .layer'));

    if (farmImg) { farmImg.src = 'https://picsum.photos/id/1040/2560/1440'; farmImg.style.objectPosition = '50% 50%'; }

    const diagVoyage = [
      'https://picsum.photos/id/1011/2560/1440',
      'https://picsum.photos/id/1015/2560/1440',
      'https://picsum.photos/id/1016/2560/1440',
      'https://picsum.photos/id/1020/2560/1440',
      'https://picsum.photos/id/1039/2560/1440',
    ];
    voyageImgs.forEach((img, i) => { img.src = diagVoyage[i % diagVoyage.length]; img.style.objectPosition = '50% 50%'; });

    if (osloImg) { osloImg.src = 'https://picsum.photos/id/1012/2560/1440'; osloImg.style.objectPosition = '50% 100%'; }
  }

  // ── Coordinates ───────────────────────────────────────────────────
  const WI   = { lat: 45.36, lng: -91.84 };
  const OSLO = { lat: 59.91, lng: 10.75 };

  if (root && farm) {
    const voyageCount = voyages.length;

    // ── ② Direct progress variable — eliminates DOM round-trip ────
    // scrollProgress is written by ScrollTrigger.onUpdate (no CSS property).
    // displayedProgress is the LERP'd version used for the coord badge.
    let scrollProgress   = 0;
    let displayedProgress = 0;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: 'top top',
        end: '+=600%',
        scrub: 1,
        pin: true,
        anticipatePin: 1,
        onUpdate: (self) => {
          // Write directly to closure variable — zero DOM overhead
          scrollProgress = self.progress;
        },
      },
    });

    // ── Panel 1: Farm ────────────────────────────────────────────
    tl.fromTo(farm, { scale: 1 }, { scale: 1.003, duration: 1.5 })
      .to(farm, { opacity: 0, duration: 0.8 }, 0.8);

    // ── Panel 2: Voyage montage ───────────────────────────────────
    const voyageDur   = 2.0;
    const perImage    = voyageCount > 0 ? voyageDur / voyageCount : voyageDur;
    const voyageStart = 0.8;

    voyages.forEach((v, i) => {
      tl.fromTo(v,
        { opacity: 0, scale: 1 },
        { opacity: 1, scale: 1.003, duration: perImage * 0.7 },
        voyageStart + i * perImage
      );
      if (i < voyageCount - 1) {
        tl.to(v, { opacity: 0, duration: perImage * 0.35 }, voyageStart + (i + 0.65) * perImage);
      } else {
        tl.to(v, { opacity: 0, duration: perImage * 0.4 }, voyageStart + voyageDur - perImage * 0.2);
      }
    });

    tl.to(grain, { opacity: 0,    duration: 1 }, voyageStart + voyageDur * 0.5);
    tl.to(vig,   { opacity: 0.25, duration: 1 }, voyageStart + voyageDur * 0.6);

    // ── Panel 3: Oslo ─────────────────────────────────────────────
    const osloStart = voyageStart + voyageDur + 0.2;
    tl.fromTo(oslo, { opacity: 0, scale: 1 }, { opacity: 1, scale: 1.003, duration: 1.2 }, osloStart);
    tl.to(grid, { opacity: 0.7, duration: 0.8 }, osloStart + 0.5);

    // ── Panel 4: Globe ────────────────────────────────────────────
    const globeStart = osloStart + 1.8;
    if (stage) tl.to(stage, { opacity: 0, duration: 0.6 }, globeStart);
    if (globeStage) tl.to(globeStage, { opacity: 1, duration: 0.6 }, globeStart + 0.1);

    // ── ③ Single ticker loop — no competing requestAnimationFrame ─
    let mapInstance: any = null;
    let mapReady   = false;
    let hasFiredFly = false;

    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    const tick = () => {
      // LERP displayedProgress toward the GSAP-scrubbed scrollProgress.
      // This gives the coord badge its own independent liquid feel at lerp=0.12.
      displayedProgress = lerp(displayedProgress, scrollProgress, 0.12);

      // Progress rail (LERP'd for smoothness)
      if (railEl) railEl.style.height = `${(displayedProgress * 100).toFixed(1)}%`;

      // Coordinate readout
      if (coordEl) {
        const lat = lerp(WI.lat, OSLO.lat, displayedProgress);
        const lng = lerp(WI.lng, OSLO.lng, displayedProgress);
        coordEl.textContent =
          `${Math.abs(lat).toFixed(1)}° ${lat >= 0 ? 'N' : 'S'}, ${Math.abs(lng).toFixed(1)}° ${lng >= 0 ? 'E' : 'W'}`;
      }

      // Globe threshold uses raw scrollProgress (binary switch, LERP not needed)
      if (globeStage) {
        if (scrollProgress >= 0.72) {
          globeStage.classList.add('is-active');
          if (mapReady && !hasFiredFly && mapInstance) {
            hasFiredFly = true;
            mapInstance.flyTo({ center: [OSLO.lng, OSLO.lat], zoom: 10, pitch: 45, bearing: -17.6, duration: 8000, essential: true });
          }
        } else {
          globeStage.classList.remove('is-active');
          hasFiredFly = false;
        }
      }
    };

    // Register with GSAP ticker — not window.scroll, not a separate RAF
    gsap.ticker.add(tick);

    // ── ④ Mapbox Globe — disposed correctly on navigation ─────────
    const initGlobe = async () => {
      if (!globeEl) return;
      try {
        const mapboxgl = (await import('mapbox-gl')).default;
        const token = (import.meta as any).env?.PUBLIC_MAPBOX_TOKEN
          || 'pk.eyJ1Ijoib2xpbnNrZSIsImEiOiJjbHh4eHh4eHgwMDAwMGpxZzh4eHh4eHh4In0.placeholder';
        mapboxgl.accessToken = token;
        mapInstance = new mapboxgl.Map({
          container: globeEl,
          style: 'mapbox://styles/mapbox/satellite-v9',
          projection: 'globe' as any,
          center: [WI.lng, WI.lat],
          zoom: 4, pitch: 55, bearing: 30,
          interactive: false,
        });
        mapInstance.on('style.load', () => {
          mapInstance.setFog({ range: [0.5, 10], color: '#020818', 'high-color': '#0a1832', 'horizon-blend': 0.08, 'space-color': '#000000', 'star-intensity': 0.3 });
          mapReady = true;
        });
      } catch (e) {
        console.warn('Mapbox GL failed to initialize:', e);
      }
    };
    initGlobe();

    // ── ⑤ Cleanup — prevents WebGL context leak on SPA navigation ─
    const cleanup = () => {
      gsap.ticker.remove(tick);
      ScrollTrigger.getAll().forEach((t) => t.kill());
      if (mapInstance) { mapInstance.remove(); mapInstance = null; }
      lenis.destroy();
    };
    // Astro view-transitions fires this before DOM swap
    document.addEventListener('astro:before-swap', cleanup, { once: true });
    // Fallback for hard unload / back-button
    window.addEventListener('pagehide', cleanup, { once: true });
  }
</script>

