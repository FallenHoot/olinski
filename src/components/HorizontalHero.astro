---
interface Card {
  title: string;
  description: string;
  href: string;
}

interface Props {
  img_wisconsin: string;
  img_mountains: string;
  img_oslo: string;
  cards?: Card[];
}

const { img_wisconsin, img_mountains, img_oslo, cards = [] } = Astro.props;

const displayCards = cards.length
  ? cards.slice(0, 3)
  : [
      { title: 'Architecting AI in the Loop', description: 'A practical runbook for shipping AI systems.', href: '/posts/' },
      { title: 'Resilient Cloud Decision Trees', description: 'Choose tradeoffs that survive Friday-night incidents.', href: '/posts/' },
      { title: 'Signal over Hype Patterns', description: 'Proven patterns from real Azure delivery work.', href: '/posts/' },
    ];
---

<div class="story-container" data-story-root>
  <!-- Fixed background stage — images cross-fade as user scrolls DOWN -->
  <div class="fixed-stage">
    <div class="image-layer" data-img="wi" style={`background-image: url(${img_wisconsin})`}></div>
    <div class="image-layer" data-img="no" style={`background-image: url(${img_mountains})`}></div>
    <div class="image-layer" data-img="os" style={`background-image: url(${img_oslo})`}></div>
    <div class="vignette"></div>
  </div>

  <!-- Reading progress line -->
  <div class="progress-rail" aria-hidden="true">
    <div class="progress-fill" data-progress-fill></div>
  </div>

  <!-- Panel 1: Wisconsin / Foundry -->
  <section class="story-panel" data-panel="wi">
    <div class="panel-content glass-tray">
      <p class="panel-kicker">ORIGIN · US NORTH CENTRAL</p>
      <h2>Northern Roots.</h2>
      <p class="panel-body">
        Wisconsin beginnings. $1,000 and a drive to build.
        I build cloud systems for Microsoft. I am building a home in Norway.
        This is how I cut through the hype to find the signal.
      </p>
      <p class="scroll-cue" aria-hidden="true">SCROLL DOWN ↓</p>
    </div>
  </section>

  <!-- Panel 2: Mountains / The Crossing -->
  <section class="story-panel" data-panel="no">
    <div class="panel-content glass-tray">
      <p class="panel-kicker">THE CROSSING · THE ATLANTIC</p>
      <h2>The Crossing.</h2>
      <p class="panel-body">
        Moving to the edge of the world. Finding home in the fjords.
        Where noise fades and architecture gets simple.
      </p>
    </div>
  </section>

  <!-- Panel 3: Oslo / Destination -->
  <section class="story-panel" data-panel="os">
    <!-- Blueprint grid overlay -->
    <div class="blueprint-overlay" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="bp-grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(77,163,255,0.12)" stroke-width="0.5"/>
          </pattern>
          <pattern id="bp-grid-major" width="200" height="200" patternUnits="userSpaceOnUse">
            <path d="M 200 0 L 0 0 0 200" fill="none" stroke="rgba(77,163,255,0.22)" stroke-width="0.8"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#bp-grid)"/>
        <rect width="100%" height="100%" fill="url(#bp-grid-major)"/>
      </svg>
    </div>
    <div class="panel-content glass-tray">
      <p class="panel-kicker">DESTINATION · NORWAY EAST (OSLO)</p>
      <h2>Oslo Monolith.</h2>
      <p class="panel-body">
        Architecting for Microsoft. Building a life in the city.
        Signal over hype. Every system should be explainable at 11 PM on a Friday.
      </p>

      <div class="card-grid">
        {displayCards.map((card) => (
          <a class="architect-card" href={card.href}>
            <p class="card-eyebrow">TECHNICAL SCHEMATIC</p>
            <h3>{card.title}</h3>
            <p class="card-desc">{card.description}</p>
            <div class="card-meta">
              <p>Region: Norway East (Oslo)</p>
              <p>Origin: US North Central (Wisconsin)</p>
              <p>Status: Deployed</p>
              <p>Provider: Azure</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</div>

<style>
  .story-container {
    position: relative;
    width: 100%;
  }

  /* ── Fixed background stage ────────────────────────────────────────── */
  .fixed-stage {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    z-index: -1;
  }

  .image-layer {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    will-change: opacity, transform;
    filter: brightness(0.55);
    transition: filter 260ms ease;
  }

  /* First image starts visible — nostalgic grain + sepia */
  .image-layer[data-img="wi"] {
    opacity: 1;
    filter: brightness(0.52) sepia(0.18) saturate(0.92);
  }

  .vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, transparent 20%, rgba(0, 0, 0, 0.4) 100%);
    pointer-events: none;
  }

  /* ── Scroll panels ────────────────────────────────────────────────── */
  .story-panel {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #f4f7ff;
    position: relative;
  }

  .panel-content {
    max-width: 860px;
    padding: 2rem;
    position: relative;
    z-index: 2;
  }

  /* Glass text tray */
  .glass-tray {
    background: rgba(10, 18, 34, 0.2);
    border: 1px solid rgba(200, 220, 255, 0.14);
    border-radius: 20px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
  }

  /* Blueprint grid overlay for Oslo */
  .blueprint-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.6;
    mix-blend-mode: screen;
  }

  /* Reading progress rail */
  .progress-rail {
    position: fixed;
    left: 0;
    top: 0;
    width: 3px;
    height: 100vh;
    z-index: 60;
    background: rgba(120, 150, 180, 0.15);
    pointer-events: none;
  }

  .progress-fill {
    width: 100%;
    height: 0%;
    background: var(--accent, #ff6b35);
    transition: height 80ms linear;
    box-shadow: 0 0 8px var(--accent, #ff6b35);
  }

  .panel-kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  .story-panel h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(3rem, 10vw, 7.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .panel-body {
    margin: 1rem 0 0;
    font-size: clamp(1rem, 1.8vw, 1.25rem);
    line-height: 1.6;
    max-width: 56ch;
    margin-inline: auto;
  }

  .scroll-cue {
    margin-top: 2rem;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    opacity: 0.7;
  }

  /* ── Architect cards ───────────────────────────────────────────────── */
  .card-grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    text-align: left;
  }

  .architect-card {
    text-decoration: none;
    color: #e9f1ff;
    border-radius: 14px;
    border: 1px solid rgba(173, 210, 255, 0.28);
    background: rgba(10, 25, 46, 0.52);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 0.85rem;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .architect-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 22px 52px rgba(5, 16, 31, 0.5);
  }

  .card-eyebrow {
    margin: 0;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    opacity: 0.8;
  }

  .architect-card h3 {
    margin: 0.4rem 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.3;
  }

  .card-desc {
    margin: 0;
    font-size: 0.88rem;
    color: #c2d4ee;
    line-height: 1.45;
  }

  .card-meta {
    margin-top: 0.6rem;
    padding-top: 0.5rem;
    border-top: 1px dashed rgba(173, 210, 255, 0.3);
  }

  .card-meta p {
    margin: 0;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    line-height: 1.55;
  }

  /* ── Theme-driven image grading ────────────────────────────────────── */
  html[data-theme='fjord'] .image-layer {
    filter: brightness(0.55) saturate(1.06) hue-rotate(-6deg);
  }

  html[data-theme='foundry'] .image-layer {
    filter: brightness(0.5) saturate(1.1) sepia(0.14) hue-rotate(-18deg);
  }

  html[data-theme='midnight'] .image-layer {
    filter: brightness(0.45) grayscale(1) contrast(1.2);
  }

  @media (max-width: 980px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { initMonolithScroll } from '../scripts/gsap-horizontal-monolith';
  initMonolithScroll();

  // ── Reading progress bar ──────────────────────────────────────────
  const progressFill = document.querySelector<HTMLElement>('[data-progress-fill]');
  const root = document.querySelector<HTMLElement>('[data-story-root]');

  // ── Scroll-bound image filters ────────────────────────────────────
  const wiLayer = document.querySelector<HTMLElement>('[data-img="wi"]');
  const noLayer = document.querySelector<HTMLElement>('[data-img="no"]');

  const onScroll = () => {
    if (!root) return;
    const progress = parseFloat(root.style.getPropertyValue('--story-progress') || '0');

    // Update progress bar height
    if (progressFill) {
      progressFill.style.height = `${(progress * 100).toFixed(1)}%`;
    }

    // Wisconsin: deepen sepia as user leaves
    if (wiLayer && wiLayer.style.opacity !== '0') {
      const sepiaAmount = 0.18 + progress * 0.25;
      wiLayer.style.filter = `brightness(0.52) sepia(${sepiaAmount.toFixed(2)}) saturate(0.92)`;
    }

    // Norway: increase saturation as user scrolls through
    if (noLayer && noLayer.style.opacity !== '0') {
      const sat = 1.0 + progress * 0.4;
      noLayer.style.filter = `brightness(0.55) saturate(${sat.toFixed(2)})`;
    }
  };

  let raf = 0;
  const tick = () => { onScroll(); raf = requestAnimationFrame(tick); };
  raf = requestAnimationFrame(tick);
  window.addEventListener('pagehide', () => cancelAnimationFrame(raf));
</script>
