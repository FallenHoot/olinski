---
interface Card {
  title: string;
  description: string;
  href: string;
}

interface Props {
  img_farm: string;
  img_oslo: string;
  voyage?: string[];
  cards?: Card[];
}

const { img_farm, img_oslo, voyage = [], cards = [] } = Astro.props;

const displayCards = cards.length
  ? cards.slice(0, 3)
  : [
      { title: 'Architecting AI in the Loop', description: 'Shipping AI with guardrails.', href: '/posts/' },
      { title: 'Resilient Cloud Decision Trees', description: 'Tradeoffs that survive Friday night.', href: '/posts/' },
      { title: 'Signal over Hype Patterns', description: 'Proven Azure delivery patterns.', href: '/posts/' },
    ];
---

<div class="montage" data-story-root>
  <!-- ═══ Three.js cinematic canvas (fixed behind text panels) ══ -->
  <canvas
    class="three-canvas"
    data-three-canvas
    data-farm={img_farm}
    data-oslo={img_oslo}
    data-voyage={JSON.stringify(voyage)}
  ></canvas>

  <!-- ═══ Cobe globe (hidden until panel 4) ═════════════════════ -->
  <div class="globe-stage" data-globe-stage>
    <canvas class="globe-canvas" data-globe-canvas width="1000" height="1000"></canvas>    <div class="globe-label" data-marker="wi">Wisconsin · 1989</div>
    <div class="globe-label" data-marker="kent">Kent · 1500s</div>
    <div class="globe-label" data-marker="ri">Rhode Island · 1700s</div>
    <div class="globe-label" data-marker="prussia">Prussia · 1800s</div>
    <div class="globe-label" data-marker="oslo">Oslo · 2024</div>  </div>

  <!-- ═══ Progress rail ══════════════════════════════════════════ -->
  <div class="rail" aria-hidden="true"><div class="rail-fill" data-rail></div></div>

  <!-- ═══ Coordinate readout ═════════════════════════════════════ -->
  <div class="coord-badge" aria-live="polite">
    <span class="coord-label">POS</span>
    <span class="coord-value" data-coord>45.3° N, 91.8° W</span>
  </div>

  <!-- ── 1. Booting Up the Local Instance (1989) ──────────────── -->
  <section id="about" class="panel story-section">
    <div class="story-content">
    <div class="tray tray-left">
      <p class="kicker">v1.0 · CADOTT, BARRON COUNTY · EST. 1989</p>
      <h2>The Local<br/>Build.</h2>
      <p class="copy">Every global deployment has a localized launch sequence. In 1989, my operating system initialized in Barron County, Wisconsin — a stable build generated by centuries of survival, adaptation, and the steady protocols of the American Midwest. This was the v1.0. The baseline from which everything scales.</p>
      <p class="cue" aria-hidden="true">SCROLL DOWN ↓</p>
    </div>
    </div>
  </section>

  <!-- ── 2. Alpha Test (1500s) ───────────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-right">
      <p class="kicker">ALPHA TEST · EAST FARLEIGH, KENT · c. 1530–1620</p>
      <h2>Before the<br/>Reboot of 1776.</h2>
      <p class="copy">We didn't just come to America — we arrived before "America" was even a defined system. In the 1500s, the Clerkes of Kent were already auditing the social and religious source code of the Old World. Living through the English Reformation, they developed a non-conformist logic that would drive them to reboot their lives in a wilderness that hadn't yet been mapped.</p>
    </div>
    </div>
  </section>

  <!-- ── 3. Architecture (1700s) ─────────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-left">
      <p class="kicker">ARCHITECTURE · NEWPORT, RHODE ISLAND · 1700–1780</p>
      <h2>The Liberty<br/>Protocol.</h2>
      <p class="copy">By the 1700s, this spirit scaled into full system architecture. My ancestors didn't just settle Rhode Island — they were the architects of its primary operating protocol: "liberty of conscience." Men like Jeremiah Clarke II built a decentralized social network that prioritized individual freedom over central authority. They were designing the blueprint for American independence a century before the 1776 rollout.</p>
    </div>
    </div>
  </section>

  <!-- ── 4. Migration (1800s) ────────────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-right">
      <p class="kicker">MIGRATION · GARNSEE, MARIENWERDER DISTRICT · 1840–1890</p>
      <h2>The Vistula<br/>Override.</h2>
      <p class="copy">While the Clark branch scaled in the colonies, a parallel migration was occurring on the Prussian frontier. The Oliński family lived in a high-stakes cultural buffer zone in the Marienwerder district, just south of Gdańsk. They practiced ultimate resilience — then executed a manual override, moving the family line from the banks of the Vistula River to the American Great Lakes.</p>
    </div>
    </div>
  </section>

  <!-- ── 5. Validation (Early 1900s) ─────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-left">
      <p class="kicker">VALIDATION · BREMERHAVEN → ELLIS ISLAND · c. 1900–1910</p>
      <h2>The Smoking<br/>Gun.</h2>
      <p class="copy">The smoking gun of the migration. This is the actual steamship that carried my great-grandmother across the Atlantic — the hardware that delivered the European source code directly into the soil of Barron County. West Prussian grit. Kentish defiance. Deployed into Wisconsin and optimized for durability through the early 20th century.</p>
    </div>
    </div>
  </section>

  <!-- ── 6. Deployment (2014) ────────────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-right">
      <p class="kicker">DEPLOYMENT · WISCONSIN → OSLO FJORD · 2014</p>
      <h2>The Global<br/>Deploy.</h2>
      <p class="copy">In 2014, I reverse-engineered the journeys of my 16th and 19th-century ancestors. Left the local servers of Wisconsin. Migrated to the cloud — the greater Oslo area. New language interface. New cultural environment. The ultimate test of the family's inherent scalability: taking 500 years of resilience and deploying it in a completely new geographic region.</p>
    </div>
    </div>
  </section>

  <!-- ── 7. Uptime (2024) ────────────────────────────────────── -->
  <section class="panel story-section">
    <div class="story-content">
    <div class="tray tray-left">
      <p class="kicker">UPTIME · OSLO, AKERSHUS · 2024 → PRESENT</p>
      <h2>500 Years of<br/>Scalability.</h2>
      <p class="copy">Over a decade in Scandinavia. The system is fully integrated. I am the descendant of Rhode Island architects, Prussian pioneers, and Wisconsin survivors. The legacy isn't just a name — it's a proven track record of high-uptime across 500 years of history. The journey that began in the forests of Barron County has found its modern uptime in Oslo.</p>

      <div class="cards">
        {displayCards.map((card) => (
          <a class="card" href={card.href}>
            <p class="card-eye">TECHNICAL SCHEMATIC</p>
            <h3>{card.title}</h3>
            <p class="card-desc">{card.description}</p>
            <div class="card-ledger">
              <p>Region: Norway East (Oslo)</p>
              <p>Origin: US North Central (WI)</p>
              <p>Status: Deployed</p>
              <p>Provider: Azure</p>
            </div>
          </a>
        ))}
      </div>
    </div>
    </div>
  </section>

  <!-- ── 8–11. Globe Journey (scroll-driven flyover) ──────────── -->
  <section class="panel story-section globe-panel">
    <div class="story-content">
    <div class="tray tray-left tray-globe">
      <p class="kicker">LEG 1 · KENT → RHODE ISLAND · 1620s</p>
      <h2>The Atlantic<br/>Crossing.</h2>
      <p class="copy">The Clerkes leave England. A one-way migration across the North Atlantic to the Rhode Island colony.</p>
    </div>
    </div>
  </section>

  <section class="panel story-section globe-panel">
    <div class="story-content">
    <div class="tray tray-right tray-globe">
      <p class="kicker">LEG 2 · RHODE ISLAND → WISCONSIN · 1800s</p>
      <h2>Westward<br/>Expansion.</h2>
      <p class="copy">The Clark branch pushes inland. From the coast of New England to the forests and farmland of the upper Midwest.</p>
    </div>
    </div>
  </section>

  <section class="panel story-section globe-panel">
    <div class="story-content">
    <div class="tray tray-left tray-globe">
      <p class="kicker">LEG 3 · PRUSSIA → WISCONSIN · 1890s</p>
      <h2>The Oliński<br/>Transfer.</h2>
      <p class="copy">The other bloodline converges. From the Vistula River to Barron County — the Prussian-Polish branch meets the Kentish-American line in Wisconsin soil.</p>
    </div>
    </div>
  </section>

  <section class="panel story-section globe-panel">
    <div class="story-content">
    <div class="tray tray-right tray-globe">
      <p class="kicker">LEG 4 · WISCONSIN → OSLO · 2014</p>
      <h2>Return to<br/>Europe.</h2>
      <p class="copy">Five centuries after leaving Kent, the line returns to Northern Europe. Full circle. High uptime.</p>
    </div>
    </div>
  </section>
</div>

<style>
  .montage { position: relative; width: 100%; height: 100vh; background: #000; }

  .story-section {
    width: 100vw;
    height: 100vh;
  }

  .story-content {
    width: 100%;
    display: flex;
    align-items: center;
  }

  /* ═══ Three.js fixed canvas ═══════════════════════════════════ */
  .three-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  /* ═══ Cobe globe stage ══════════════════════════════════════════ */
  .globe-stage {
    position: fixed; inset: 0; z-index: 1;
    opacity: 0; pointer-events: none;
    display: flex; align-items: center; justify-content: center;
    background: #000;
  }

  .globe-stage.is-active {
    pointer-events: auto;
  }

  .globe-canvas {
    width: min(90vw, 90vh);
    height: min(90vw, 90vh);
  }

  .globe-label {
    position: absolute;
    padding: 0.25rem 0.6rem;
    background: rgba(6, 14, 28, 0.85);
    border: 1px solid rgba(200, 220, 255, 0.2);
    border-radius: 4px;
    color: #d0e2ff;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    white-space: nowrap;
    pointer-events: none;
    transition: opacity 0.3s, filter 0.3s;
  }

  .globe-label[data-marker="wi"] {
    position-anchor: --cobe-wi;
    bottom: anchor(top);
    left: anchor(center);
    translate: -50% 0;
    margin-bottom: 6px;
    opacity: var(--cobe-visible-wi, 0);
    filter: blur(calc((1 - var(--cobe-visible-wi, 0)) * 6px));
  }
  .globe-label[data-marker="kent"] {
    position-anchor: --cobe-kent;
    bottom: anchor(top);
    left: anchor(center);
    translate: -50% 0;
    margin-bottom: 6px;
    opacity: var(--cobe-visible-kent, 0);
    filter: blur(calc((1 - var(--cobe-visible-kent, 0)) * 6px));
  }
  .globe-label[data-marker="ri"] {
    position-anchor: --cobe-ri;
    bottom: anchor(top);
    left: anchor(center);
    translate: -50% 0;
    margin-bottom: 6px;
    opacity: var(--cobe-visible-ri, 0);
    filter: blur(calc((1 - var(--cobe-visible-ri, 0)) * 6px));
  }
  .globe-label[data-marker="prussia"] {
    position-anchor: --cobe-prussia;
    bottom: anchor(top);
    left: anchor(center);
    translate: -50% 0;
    margin-bottom: 6px;
    opacity: var(--cobe-visible-prussia, 0);
    filter: blur(calc((1 - var(--cobe-visible-prussia, 0)) * 6px));
  }
  .globe-label[data-marker="oslo"] {
    position-anchor: --cobe-oslo;
    bottom: anchor(top);
    left: anchor(center);
    translate: -50% 0;
    margin-bottom: 6px;
    opacity: var(--cobe-visible-oslo, 0);
    filter: blur(calc((1 - var(--cobe-visible-oslo, 0)) * 6px));
  }

  /* ═══ Panels ══════════════════════════════════════════════════ */
  .panel {
    position: absolute; inset: 0;
    z-index: 2;
    display: flex; align-items: center;
    color: #f0f4ff;
    opacity: 0;
    pointer-events: none;
  }

  .panel:first-of-type {
    opacity: 1;
    pointer-events: auto;
  }

  .tray {
    max-width: 720px;
    padding: clamp(1rem, 2.2vw, 1.8rem) clamp(1rem, 2.2vw, 1.6rem);
    background: linear-gradient(90deg, rgba(8,14,24,0.34), rgba(8,14,24,0.08) 72%, transparent);
    border-left: 2px solid rgba(212,225,242,0.45);
    border-radius: 0;
    box-shadow: none;
    position: relative; z-index: 3;
  }

  /* Off-axis layouts — Mont-Fort style */
  .tray-left { margin-left: clamp(2rem,6vw,5rem); }
  .tray-right { margin-left: auto; margin-right: clamp(2rem,6vw,5rem); }

  .tray-globe { margin-bottom: auto; margin-top: clamp(4rem,12vh,8rem); }

  .kicker {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono, Consolas, monospace);
    font-size: 0.7rem; letter-spacing: 0.14em;
    text-transform: uppercase; opacity: 0.75;
  }

  .panel h2 {
    margin: 0; font-family: var(--font-display);
    font-size: clamp(2.1rem, 6.2vw, 6.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 0.95;
    text-transform: none;
  }

  .copy {
    margin: 1.1rem 0 0;
    max-width: 54ch;
    font-size: clamp(0.98rem, 1.2vw, 1.16rem);
    line-height: 1.68;
    color: rgba(231,238,248,0.92);
  }
  .cue { margin-top: 2rem; font-family: var(--font-mono, Consolas, monospace); font-size: 0.76rem; letter-spacing: 0.14em; opacity: 0.55; }

  /* ═══ Progress rail ═══════════════════════════════════════════ */
  .rail { position: fixed; left: 0; top: 0; width: 3px; height: 100vh; z-index: 60; background: rgba(120,150,180,0.1); pointer-events: none; }
  .rail-fill { width: 100%; height: 0%; background: var(--accent, #ff6b35); box-shadow: 0 0 8px var(--accent, #ff6b35); transition: height 80ms linear; }

  /* ═══ Coord badge ═════════════════════════════════════════════ */
  .coord-badge {
    position: fixed; right: clamp(0.8rem,2vw,1.6rem); bottom: clamp(0.8rem,2vw,1.4rem);
    z-index: 60; display: flex; gap: 0.5rem; align-items: baseline;
    padding: 0.35rem 0.65rem; border-radius: 10px;
    border: 1px solid rgba(200,220,255,0.12);
    background: rgba(6,14,28,0.72);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    color: #d0e2ff; font-family: var(--font-mono, Consolas, monospace); pointer-events: none;
  }
  .coord-label { font-size: 0.62rem; letter-spacing: 0.14em; opacity: 0.65; }
  .coord-value { font-size: 0.82rem; font-weight: 600; font-variant-numeric: tabular-nums; }

  /* ═══ Cards ═══════════════════════════════════════════════════ */
  .cards { margin-top: 1.5rem; display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
  .card {
    text-decoration: none;
    color: #e6efff;
    border-radius: 0;
    border: 0;
    border-top: 1px solid rgba(196,214,236,0.24);
    background: transparent;
    padding: 0.9rem 0.1rem;
    transition: transform 180ms ease, border-color 180ms ease;
  }
  .card:hover { transform: translateX(4px); border-color: rgba(227,237,249,0.58); }
  .card-eye { margin: 0; font-family: var(--font-mono, Consolas, monospace); font-size: 0.66rem; letter-spacing: 0.06em; opacity: 0.72; }
  .card h3 { margin: 0.4rem 0; font-family: var(--font-display); font-size: 1rem; line-height: 1.3; }
  .card-desc { margin: 0; font-size: 0.9rem; color: #c6d5ea; line-height: 1.55; }
  .card-ledger { margin-top: 0.5rem; padding-top: 0.45rem; border-top: 0; }
  .card-ledger p { margin: 0; font-family: var(--font-mono, Consolas, monospace); font-size: 0.66rem; letter-spacing: 0.05em; line-height: 1.55; opacity: 0.78; }

  /* ═══ Mobile layout ═══════════════════════════════════════════ */
  @media (max-aspect-ratio: 3/4) {
    .panel { align-items: flex-end; padding-bottom: env(safe-area-inset-bottom, 1.5rem); }
    .tray { margin-bottom: clamp(1rem, 4vh, 2.5rem); max-width: 100%; }
    .tray-left, .tray-right { margin-left: 0.75rem; margin-right: 0.75rem; }
  }

  @media (max-width: 980px) {
    .tray-left, .tray-right { margin-left: 1rem; margin-right: 1rem; max-width: 100%; }
    .panel h2 { font-size: clamp(2rem, 10vw, 4rem); }
    .kicker { font-size: 0.62rem; }
    .copy { font-size: 0.95rem; }
    .coord-badge { bottom: auto; top: clamp(0.5rem, 2vw, 1rem); right: clamp(0.5rem, 2vw, 1rem); }
  }

  @media (max-width: 768px) {
    .story-section {
      height: 100svh;
    }
  }

  @media (max-width: 480px) {
    .tray { padding: 1rem; border-radius: 16px; }
    .panel h2 { font-size: clamp(1.6rem, 12vw, 2.4rem); }
    .cards { gap: 0.5rem; }
    .card { padding: 0.7rem; }
    .card h3 { font-size: 0.9rem; }
    .rail { width: 2px; }
  }

  /* Large / ultrawide screens */
  @media (min-width: 1600px) {
    .tray { max-width: 640px; padding: 2.5rem; }
    .copy { font-size: 1.25rem; max-width: 52ch; }
    .tray-left { margin-left: clamp(4rem, 8vw, 10rem); }
    .tray-right { margin-right: clamp(4rem, 8vw, 10rem); }
  }

  @media (min-width: 2400px) {
    .tray { max-width: 780px; }
    .panel h2 { font-size: 7rem; }
  }

  @media (min-width: 2000px) {
    .story-content {
      max-width: min(1280px, calc(100vw - 4rem));
      margin-inline: auto;
    }
    .tray-left,
    .tray-right {
      margin-left: 0;
      margin-right: 0;
    }
    .tray-right {
      margin-left: auto;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .globe-stage { transition: none !important; animation: none !important; }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import Lenis from 'lenis';
  import { SceneController } from '../scripts/scene-controller';
  gsap.registerPlugin(ScrollTrigger);

  // ── ① Lenis virtual scroll — single RAF source, premium-heavy feel ──
  const lenis = new Lenis({ lerp: 0.1, syncTouch: false });
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);
  lenis.on('scroll', () => ScrollTrigger.update());
  ScrollTrigger.addEventListener('refresh', () => lenis.resize());

  const root       = document.querySelector<HTMLElement>('[data-story-root]');
  const canvas     = document.querySelector<HTMLCanvasElement>('[data-three-canvas]');
  const globeStage = document.querySelector<HTMLElement>('[data-globe-stage]');
  const globeCanvas = document.querySelector<HTMLCanvasElement>('[data-globe-canvas]');
  const coordEl    = document.querySelector<HTMLElement>('[data-coord]');
  const railEl     = document.querySelector<HTMLElement>('[data-rail]');
  const panels     = Array.from(document.querySelectorAll<HTMLElement>('.panel'));

  if (root && canvas) {
    // Parse image paths from data attributes
    const farmPath    = canvas.dataset.farm!;
    const osloPath    = canvas.dataset.oslo!;
    const voyagePaths: string[] = JSON.parse(canvas.dataset.voyage || '[]');

    const images = [
      { key: 'farm', path: farmPath },
      ...voyagePaths.map((p: string, i: number) => ({ key: `voyage${i}`, path: p })),
      { key: 'oslo', path: osloPath },
    ];

    // ── ② Three.js scene — LoadingManager gate ───────────────────
    const sc = new SceneController(canvas);

    sc.load(images).then(() => {
      const voyageCount = voyagePaths.length;

      // ── ③ Progress variable — closure, zero DOM overhead ────────
      let scrollProgress    = 0;
      let displayedProgress = 0;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: root,
          start: 'top top',
          end: '+=1100%',
          scrub: 1,
          pin: true,
          anticipatePin: 1,
          onUpdate: (self) => { scrollProgress = self.progress; },
        },
      });

      // ── Timeline — 8 panels, one image per chapter ─────────────
      // 800% total → each panel ~12.5% of progress
      // Panel 1: farm (t=0–1)    Panel 2: voyage0 (t=1–2)
      // Panel 3: voyage1 (t=2–3) Panel 4: voyage2 (t=3–4)
      // Panel 5: voyage3 (t=4–5) Panel 6: voyage4 (t=5–6)
      // Panel 7: oslo (t=6–7)    Panel 8: globe (t=7–8)

      const panelDur = 1.0;

      // ── Chapter I: Wisconsin (t = 0 → 1) ──────────────────────
      tl.fromTo(sc.scale('farm'), { value: 1 }, { value: 1.006, duration: panelDur });
      tl.to(sc.opacity('farm'), { value: 0, duration: 0.3 }, panelDur - 0.3);

      // ── Chapters II–VI: Voyage images (t = 1 → 6) ─────────────
      for (let i = 0; i < voyageCount; i++) {
        const key = `voyage${i}`;
        const start = panelDur * (i + 1);

        tl.fromTo(sc.opacity(key), { value: 0 }, { value: 1, duration: 0.3 }, start);
        tl.fromTo(sc.scale(key), { value: 1 }, { value: 1.005, duration: panelDur }, start);
        tl.to(sc.opacity(key), { value: 0, duration: 0.3 }, start + panelDur - 0.3);
      }

      // ── Chapter VII: Oslo (t = 6 → 7) ─────────────────────────
      const osloStart = panelDur * 6;
      tl.fromTo(sc.opacity('oslo'), { value: 0 }, { value: 1, duration: 0.3 }, osloStart);
      tl.fromTo(sc.scale('oslo'), { value: 1 }, { value: 1.005, duration: panelDur }, osloStart);
      tl.to(sc.grid('oslo'), { value: 0.4, duration: 0.5 }, osloStart + 0.4);
      tl.to(sc.opacity('oslo'), { value: 0, duration: 0.3 }, osloStart + panelDur - 0.2);

      // ── Chapter VIII–XI: Globe journey (t = 7 → 11) ──────────
      const globeStart = panelDur * 7;
      tl.to(canvas, { opacity: 0, duration: 0.3 }, globeStart);
      if (globeStage) tl.to(globeStage, { opacity: 1, duration: 0.4 }, globeStart + 0.1);

      // ── Text panel fade in/out — synced to image chapters ──────
      panels.forEach((panel, i) => {
        const start = panelDur * i;
        // Fade in
        tl.fromTo(panel,
          { opacity: 0, pointerEvents: 'none' },
          { opacity: 1, pointerEvents: 'auto', duration: 0.25 },
          i === 0 ? 0 : start,
        );
        // Fade out (except the last panel which stays)
        if (i < panels.length - 1) {
          tl.to(panel,
            { opacity: 0, pointerEvents: 'none', duration: 0.25 },
            start + panelDur - 0.25,
          );
        }
      });

      // ── ④ Single ticker loop ───────────────────────────────────
      // Coordinate waypoints trace the genealogy journey
      const WAYPOINTS = [
        { lat: 45.36, lng: -91.34 },  // 1. Cadott, Wisconsin (1989)
        { lat: 51.24, lng:   0.51 },  // 2. Kent, England (1500s)
        { lat: 41.82, lng: -71.41 },  // 3. Rhode Island (1700s)
        { lat: 53.75, lng:  18.93 },  // 4. Marienwerder, Prussia (1800s)
        { lat: 44.93, lng: -91.68 },  // 5. Chippewa County, WI (1900s)
        { lat: 45.36, lng: -91.34 },  // 6. Cadott, WI (2014)
        { lat: 59.91, lng:  10.75 },  // 7. Oslo, Norway (2024)
        { lat: 59.91, lng:  10.75 },  // 8. Globe (stay at Oslo)
      ];

      let globeInstance: any = null;
      let globeActive = false;

      // Cobe internals: marker([lat,lng]) → 3D via a = lng*PI/180 - PI
      // To center longitude X: phi = PI - X*PI/180
      // theta ≈ 0.2–0.4 for northern hemisphere (higher = more tilt toward north pole)
      const GLOBE_STOPS = [
        { phi: 3.13, theta: 0.30 },  // Kent (0.5°E) — PI
        { phi: 4.39, theta: 0.25 },  // Rhode Island (-71°W)
        { phi: 4.74, theta: 0.28 },  // Wisconsin (-91°W)
        { phi: 2.81, theta: 0.32 },  // Prussia (19°E)
        { phi: 2.95, theta: 0.35 },  // Oslo (10.7°E)
      ];

      // Use Kent as starting phi but unwrapped for smooth LERP
      let targetPhi   = GLOBE_STOPS[0].phi;
      let targetTheta = GLOBE_STOPS[0].theta;
      let currentPhi   = targetPhi;
      let currentTheta = targetTheta;

      let currentLeg = 0;

      const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

      const tick = () => {
        displayedProgress = lerp(displayedProgress, scrollProgress, 0.12);

        if (railEl) railEl.style.height = `${(displayedProgress * 100).toFixed(1)}%`;

        // Interpolate coordinates between waypoints
        if (coordEl) {
          const totalSegments = WAYPOINTS.length - 1;
          const scaledProgress = displayedProgress * totalSegments;
          const segIndex = Math.min(Math.floor(scaledProgress), totalSegments - 1);
          const segT = scaledProgress - segIndex;
          const from = WAYPOINTS[segIndex];
          const to = WAYPOINTS[segIndex + 1];
          const lat = lerp(from.lat, to.lat, segT);
          const lng = lerp(from.lng, to.lng, segT);
          coordEl.textContent =
            `${Math.abs(lat).toFixed(1)}° ${lat >= 0 ? 'N' : 'S'}, ${Math.abs(lng).toFixed(1)}° ${lng >= 0 ? 'E' : 'W'}`;
        }

        // Globe panels span from 7/11 to 11/11 of total progress
        const globeThreshold = 7 / 11;
        if (globeStage) {
          if (scrollProgress >= globeThreshold) {
            if (!globeActive) {
              globeActive = true;
              globeStage.classList.add('is-active');
            }

            // 4 globe panels: each gets 1/11 of total progress
            const globeLocalProgress = (scrollProgress - globeThreshold) / (1 - globeThreshold);
            // Which leg are we on? (0–3)
            const legIndex = Math.min(Math.floor(globeLocalProgress * 4), 3);
            const legT = (globeLocalProgress * 4) - legIndex;
            currentLeg = legIndex;

            // Fly camera between stops
            const fromStop = GLOBE_STOPS[legIndex];
            const toStop = GLOBE_STOPS[legIndex + 1];
            targetPhi = lerp(fromStop.phi, toStop.phi, legT);
            targetTheta = lerp(fromStop.theta, toStop.theta, legT);

            // Update arcs progressively
            if (globeInstance) {
              const allArcs = [
                { from: [51.24, 0.51], to: [41.82, -71.41], color: [0.6, 0.7, 1.0] as [number,number,number] },
                { from: [41.82, -71.41], to: [45.36, -91.34], color: [0.6, 0.7, 1.0] as [number,number,number] },
                { from: [53.75, 18.93], to: [45.36, -91.34], color: [1.0, 0.6, 0.3] as [number,number,number] },
                { from: [45.36, -91.34], to: [59.91, 10.75], color: [1, 0.42, 0.21] as [number,number,number] },
              ];
              // Show arcs up to and including current leg
              const visibleArcs = allArcs.slice(0, legIndex + 1);
              globeInstance.update({
                phi: currentPhi,
                theta: currentTheta,
                arcs: visibleArcs,
              });
            }
          } else {
            if (globeActive) {
              globeActive = false;
              globeStage.classList.remove('is-active');
            }
          }
        }

        // LERP globe rotation
        currentPhi   = lerp(currentPhi, targetPhi, 0.08);
        currentTheta = lerp(currentTheta, targetTheta, 0.08);

        // Render Three.js scene
        sc.tick();
      };

      gsap.ticker.add(tick);

      // ── Resize handler ─────────────────────────────────────────
      const onResize = () => sc.resize();
      window.addEventListener('resize', onResize);

      // ── ⑤ Cobe Globe — zero API keys, zero cost ────────────────
      const initGlobe = async () => {
        if (!globeCanvas) return;
        try {
          const createGlobe = (await import('cobe')).default;
          globeInstance = createGlobe(globeCanvas, {
            devicePixelRatio: Math.min(window.devicePixelRatio, 2),
            width: 1000,
            height: 1000,
            phi: currentPhi,
            theta: currentTheta,
            dark: 0,
            diffuse: 1.2,
            scale: 1,
            mapSamples: 16000,
            mapBrightness: 6,
            mapBaseBrightness: 0.05,
            baseColor: [0.3, 0.3, 0.3],
            markerColor: [1, 0.42, 0.21],
            glowColor: [0.15, 0.15, 0.2],
            markers: [
              { location: [51.24,   0.51], size: 0.05, id: 'kent' },
              { location: [41.82, -71.41], size: 0.05, id: 'ri' },
              { location: [45.36, -91.34], size: 0.06, id: 'wi' },
              { location: [53.75,  18.93], size: 0.05, id: 'prussia' },
              { location: [59.91,  10.75], size: 0.06, id: 'oslo' },
            ],
            arcs: [],
            arcColor: [1, 0.42, 0.21],
            arcWidth: 0.5,
            arcHeight: 0.3,
          });
        } catch (e) {
          console.warn('Cobe globe failed to initialize:', e);
        }
      };
      initGlobe();

      // ── ⑥ Cleanup — prevents WebGL context leak ────────────────
      const cleanup = () => {
        gsap.ticker.remove(tick);
        ScrollTrigger.getAll().forEach((t) => t.kill());
        window.removeEventListener('resize', onResize);
        if (globeInstance) { globeInstance.destroy(); globeInstance = null; }
        sc.dispose();
        lenis.destroy();
      };
      document.addEventListener('astro:before-swap', cleanup, { once: true });
      window.addEventListener('pagehide', cleanup, { once: true });
    });
  }
</script>
