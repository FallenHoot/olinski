---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.status === 'published' || data.status === 'scheduled');
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Olinske`} description={post.data.description}>
  <main class="container site-shell">
    <article class="panel article fade-in">
      <p class="eyebrow">
        {post.data.publishDate.toISOString().slice(0, 10)}
      </p>
      <h1>{post.data.title}</h1>
      <p class="hero-subtitle">{post.data.description}</p>
      <hr style="border: 0; border-top: 1px solid var(--border); margin: 1.5rem 0;" />
      <Content />
    </article>
  </main>
</BaseLayout>
