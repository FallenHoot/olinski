---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => data.status === 'published' || data.status === 'scheduled'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Posts | Olinske" description="Published and scheduled posts from Olinske.">
  <main class="container site-shell">
    <section class="panel section fade-in">
      <p class="eyebrow">Archive</p>
      <h1>Posts</h1>
      {
        posts.length === 0 ? (
          <p class="post-meta">No published posts yet.</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li>
                <a href={`/posts/${post.id.replace(/\.md$/, '')}/`}>{post.data.title}</a>
                <div class="post-meta">{post.data.publishDate.toISOString().slice(0, 10)}</div>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </main>
</BaseLayout>
