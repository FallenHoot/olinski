---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => data.status === 'published' || data.status === 'scheduled'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const estimateReadTime = (body?: string) => {
  const wordCount = (body ?? '').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(wordCount / 220));
};
---

<BaseLayout title="Posts | Olinske" description="Published and scheduled posts from Olinske.">
  <main class="container site-shell">
    <section class="hero-panel fade-in">
      <p class="eyebrow">Archive</p>
      <h1 class="hero-title">Technical Articles</h1>
      <p class="hero-subtitle">Engineering notes, cloud architecture patterns, and AI operating guidance.</p>
    </section>

    <section class="feed-grid fade-in fade-delay-1">
      {
        posts.length === 0 ? (
          <article class="post-card">
            <div class="post-thumb" aria-hidden="true"></div>
            <div class="post-content">
              <h3>No published posts yet.</h3>
            </div>
          </article>
        ) : (
          posts.map((post) => (
            <article class="post-card">
              <a class="post-card-link" href={`/posts/${post.id.replace(/\.md$/, '')}/`}>
                <div class="post-thumb" aria-hidden="true"></div>
                <div class="post-content">
                  <div class="tag-row">
                    {(post.data.tags ?? []).slice(0, 3).map((tag) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <p class="post-meta">{post.data.publishDate.toISOString().slice(0, 10)} · {estimateReadTime(post.body)} min read</p>
                </div>
              </a>
            </article>
          ))
        )
      }
    </section>
  </main>
</BaseLayout>
