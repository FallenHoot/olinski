---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalHero from '../components/HorizontalHero.astro';
import { getCollection } from 'astro:content';

// Era 1: 1500s — tall ships / old maps
const img_1500s = '/images/1500s-voyage.jpg';
// Era 2: 1900s — steamship / Wisconsin settlement
const img_1900s = '/images/1900s-steamship.jpg';
// Era 3: Modern — Oslo skyline / Barcode district
const img_oslo = '/images/oslo-skyline.jpg';

const posts = (
  await getCollection('posts', ({ data }) =>
    data.status === 'published' || data.status === 'scheduled'
  )
)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    href: `/posts/${post.id.replace(/\.md$/, '')}/`
  }));
---

<BaseLayout title="Olinske | Signal Over Hype">
  <HorizontalHero img_wisconsin={img_1500s} img_mountains={img_1900s} img_oslo={img_oslo} cards={posts} />
</BaseLayout>
