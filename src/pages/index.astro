---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const publishedPosts = (await getCollection('posts', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Olinske | Signal Over Hype">
  <main class="container" style="padding: 3.5rem 0 4.5rem;">
    <section class="card" style="padding: 2rem; margin-bottom: 1.5rem;">
      <p style="margin: 0 0 0.75rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; font-size: 0.78rem;">Olinske | Zach Olinske</p>
      <h1 style="margin: 0 0 0.7rem; font-size: clamp(1.8rem, 4vw, 3rem); line-height: 1.12;">Signal Over Hype.</h1>
      <p style="margin: 0; max-width: 68ch; color: var(--muted);">Practical guidance for CTOs and enterprise leaders on AI readiness, cloud resilience, and operating model decisions.</p>
    </section>

    <section class="card" style="padding: 1.5rem 2rem;">
      <h2 style="margin-top: 0;">Now in progress</h2>
      <ul>
        <li>Issue-driven editorial workflow</li>
        <li>Research, draft, and review helper agents</li>
        <li>LinkedIn-first distribution playbook</li>
      </ul>
    </section>

    <section class="card" style="padding: 1.5rem 2rem; margin-top: 1.5rem;">
      <h2 style="margin-top: 0;">Latest published posts</h2>
      {
        publishedPosts.length === 0 ? (
          <p style="margin: 0; color: var(--muted);">No published posts yet. Drafts are still moving through review.</p>
        ) : (
          <ul>
            {publishedPosts.map((post) => (
              <li><a href={`/posts/${post.id.replace(/\.md$/, '')}/`}>{post.data.title}</a> - {post.data.publishDate.toISOString().slice(0, 10)}</li>
            ))}
          </ul>
        )
      }
      <p style="margin: 1rem 0 0;"><a href="/posts/">View all posts</a></p>
    </section>
  </main>
</BaseLayout>
