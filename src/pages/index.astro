---
import BaseLayout from '../layouts/BaseLayout.astro';
import HorizontalHero from '../components/HorizontalHero.astro';
import { getCollection } from 'astro:content';

const img_wisconsin = 'https://images.unsplash.com/photo-1472396961693-142e6e269027?auto=format&fit=crop&w=1600&q=80';
const img_mountains = 'https://images.unsplash.com/photo-1464822759844-d150ad6d1d00?auto=format&fit=crop&w=1600&q=80';
const img_oslo = 'https://images.unsplash.com/photo-1593888566144-6f2db0f2f8d8?auto=format&fit=crop&w=1600&q=80';

const posts = (
  await getCollection('posts', ({ data }) =>
    data.status === 'published' || data.status === 'scheduled'
  )
)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3)
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    href: `/posts/${post.id.replace(/\.md$/, '')}/`
  }));
---

<BaseLayout title="Olinske | Signal Over Hype">
  <HorizontalHero img_wisconsin={img_wisconsin} img_mountains={img_mountains} img_oslo={img_oslo} cards={posts} />

</BaseLayout>
