---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const publishedPosts = (await getCollection('posts', ({ data }) => data.status === 'published' || data.status === 'scheduled'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 9);

const estimateReadTime = (body?: string) => {
  const wordCount = (body ?? '').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(wordCount / 220));
};
---

<BaseLayout title="Olinske | Signal Over Hype">
  <main class="container site-shell">
    <section class="hero-panel fade-in">
      <p class="eyebrow">American-Norwegian Cloud Journal</p>
      <h1 class="hero-title">Signal Over Hype for Cloud Architects.</h1>
      <p class="hero-subtitle">
        Enterprise AI, resilient cloud systems, and technical leadership playbooks.
        Clean Nordic structure with bold, practical execution.
      </p>
      <div class="hero-actions">
        <a class="btn-link" href="/posts/">Read Latest Articles</a>
        <a class="btn-link btn-muted" href="#about">About This Lab</a>
      </div>
    </section>

    <section class="feed-head fade-in fade-delay-1">
      <h2>Discovery Feed</h2>
      <p class="post-meta">Scroll through architecture notes, operational playbooks, and AI strategy essays.</p>
    </section>

    <section class="feed-grid fade-in fade-delay-2">
      {
        publishedPosts.length === 0 ? (
          <article class="post-card">
            <div class="post-thumb" aria-hidden="true"></div>
            <div class="post-content">
              <h3>No published posts yet</h3>
              <p class="post-meta">Run the editorial workflow and publish your first post.</p>
            </div>
          </article>
        ) : (
          publishedPosts.map((post) => (
            <article class="post-card">
              <a class="post-card-link" href={`/posts/${post.id.replace(/\.md$/, '')}/`}>
                <div class="post-thumb" aria-hidden="true"></div>
                <div class="post-content">
                  <div class="tag-row">
                    {(post.data.tags ?? []).slice(0, 3).map((tag) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <p class="post-meta">{post.data.publishDate.toISOString().slice(0, 10)} · {estimateReadTime(post.body)} min read</p>
                </div>
              </a>
            </article>
          ))
        )
      }
    </section>

    <section id="about" class="about-panel fade-in fade-delay-2">
      <h2>About the Lab</h2>
      <p>
        This site combines Nordic minimalism with American directness.
        The Lab icon in the top-right cycles between Nordic Light, Deep Cloud, and High-Contrast themes.
      </p>
    </section>
  </main>
</BaseLayout>
