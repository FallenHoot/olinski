---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const requestedTheme = Astro.url.searchParams.get('theme') ?? 'executive';
const activeTheme = ['executive', 'operator', 'horizon'].includes(requestedTheme)
  ? requestedTheme
  : 'executive';

const themeContent = {
  executive: {
    eyebrow: 'Olinske | Strategic Counsel',
    title: 'Signal Over Hype.',
    subtitle: 'Trusted guidance for CTOs and enterprise leaders navigating AI readiness, cloud resilience, and operating model transformation.'
  },
  operator: {
    eyebrow: 'Olinske | Execution Blueprint',
    title: 'Build with precision.',
    subtitle: 'No fluff. Frameworks, decisions, and clear thinking on enterprise AI, infrastructure decisions, and CTO-level challenges.'
  },
  horizon: {
    eyebrow: 'Olinske | Future of Enterprise',
    title: 'Where enterprise is headed.',
    subtitle: 'Exploring the intersection of AI, resilience, and leadership. Insights for CTOs ready to shape what\'s next.'
  }
};

const content = themeContent[activeTheme];
const publishedPosts = (await getCollection('posts', ({ data }) => data.status === 'published'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Olinske | Signal Over Hype">
  <main class="container site-shell">
    <section class="panel hero fade-in">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1 class="hero-title">{content.title}</h1>
      <p class="hero-subtitle">{content.subtitle}</p>
    </section>

    <section class="grid">
      <article class="panel section grid-main fade-in fade-delay-1">
        <h2>Latest published posts</h2>
        {
          publishedPosts.length === 0 ? (
            <p class="post-meta">No published posts yet. Drafts are still moving through review.</p>
          ) : (
            <ul class="post-list">
              {publishedPosts.map((post) => (
                <li>
                  <a href={`/posts/${post.id.replace(/\.md$/, '')}/`}>{post.data.title}</a>
                  <div class="post-meta">{post.data.publishDate.toISOString().slice(0, 10)}</div>
                </li>
              ))}
            </ul>
          )
        }
        <a class="btn-link" href="/posts/">View all posts</a>
      </article>

      <aside class="panel section grid-side fade-in fade-delay-2">
        <h2>Now in progress</h2>
        <ul>
          <li>Issue-driven editorial workflow</li>
          <li>Research, draft, and review helper agents</li>
          <li>LinkedIn-first distribution playbook</li>
        </ul>

        <h2 style="margin-top: 1.2rem;">Theme Lab</h2>
        <div class="theme-lab">
          <a class="theme-link" href="/?theme=executive">
            <strong>Executive Editorial</strong>
            <span>Warm premium tone, high trust, boardroom readability.</span>
          </a>
          <a class="theme-link" href="/?theme=operator">
            <strong>Operator Blueprint</strong>
            <span>Cool analytical feel, technical clarity, execution-first.</span>
          </a>
          <a class="theme-link" href="/?theme=horizon">
            <strong>Strategic Horizon</strong>
            <span>Forward-looking narrative style with strong visual warmth.</span>
          </a>
        </div>
      </aside>
    </section>

    <section class="panel section fade-in fade-delay-2" style="margin-top: 1.1rem;">
      <h2>CTO Return Criteria</h2>
      <ul class="criteria-list">
        <li>Can skim key ideas in under 90 seconds.</li>
        <li>Every post has one concrete framework or decision model.</li>
        <li>Visual tone feels credible, calm, and non-gimmicky.</li>
        <li>Navigation makes it obvious what to read next.</li>
      </ul>
    </section>
  </main>
</BaseLayout>
