---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (
  await getCollection('posts', ({ data }) =>
    data.status === 'published' || data.status === 'scheduled'
  )
)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

const estimateReadTime = (body?: string) => {
  const words = (body ?? '').trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 220));
};

const intelPosts = posts.slice(0, 3);
const feedPosts  = posts.slice(3);
---

<BaseLayout title="Olinske | Signal Over Hype">

  <!-- ═══════════════════════════════════════════════════════════════
       HORIZONTAL MONOLITH — 3 panels, managed by GSAP ScrollTrigger
       ═══════════════════════════════════════════════════════════════ -->
  <div data-mono-wrapper class="mono-wrapper" aria-label="Interactive feature section">

    <div data-mono-track class="mono-track">

      <!-- ── Panel 1: The Monolith Hero ──────────────────────────── -->
      <section
        data-mono-panel
        class="mono-panel panel-hero"
        aria-label="Signal Over Hype — hero"
      >
        <div data-frost-layer class="frost-layer">
          <div class="hero-inner">

            <!-- 3D Monolith shape -->
            <div data-monolith-wrap class="monolith-wrap" aria-hidden="true">
              <div class="monolith">
                <div class="m-face m-front"></div>
                <div class="m-face m-right"></div>
                <div class="m-face m-top"></div>
              </div>
            </div>

            <!-- Copy -->
            <div class="hero-copy">
              <h1 class="mono-headline">SIGNAL<br>OVER<br>HYPE.</h1>
              <p class="mono-sub">
                Enterprise AI, resilient cloud systems, and technical leadership
                playbooks. Nordic clarity. American directness.
              </p>
              <div class="mono-cta">
                <a class="btn-link" href="/posts/">Read Articles</a>
                <a class="btn-link btn-muted" href="#about">About the Lab</a>
              </div>
            </div>

          </div>
        </div>

        <p class="panel-hint" aria-hidden="true">
          SCROLL <span class="hint-arrow">→</span>
        </p>
      </section>

      <!-- ── Panel 2: Nordic Philosophy ──────────────────────────── -->
      <section
        data-mono-panel
        class="mono-panel panel-philosophy"
        aria-label="Nordic Philosophy"
      >
        <div data-frost-layer class="frost-layer">
          <div class="philosophy-block">
            <span class="philosophy-tag">The Principle</span>
            <h2 class="philosophy-headline">Clarity<br>Beats<br>Complexity.</h2>
            <hr class="philosophy-rule" />
            <p class="philosophy-body">
              Cloud architecture is not a vendor decision. It is a strategic posture.
              The best systems are the ones you can explain to a CFO and defend
              on a Friday at 11&nbsp;PM when everything is down.
              This journal documents what survives first contact with production.
            </p>
            <p class="philosophy-body" style="margin-top:1.25rem;">
              Nordic&ndash;Finnish design taught the world that structure and restraint
              unlock more freedom than ornamentation. The same principle applies
              to distributed systems and the organisations that run them.
            </p>
          </div>
        </div>
      </section>

      <!-- ── Panel 3: Recent Intel ────────────────────────────────── -->
      <section
        data-mono-panel
        class="mono-panel panel-intel"
        aria-label="Recent Intel — latest posts"
      >
        <div data-frost-layer class="frost-layer">
          <div class="intel-block">
            <p class="intel-label">// recent intel</p>
            <h2 class="intel-title">Latest from the Lab</h2>

            <div class="intel-cards">
              {
                intelPosts.length === 0 ? (
                  <div class="intel-card">
                    <p class="intel-meta">COMING SOON</p>
                    <h3>First post in the pipeline.</h3>
                    <p>Check back after running the editorial workflow.</p>
                  </div>
                ) : (
                  intelPosts.map((post) => (
                    <a
                      class="intel-card"
                      href={`/posts/${post.id.replace(/\.md$/, '')}/`}
                    >
                      <p class="intel-meta">
                        {post.data.publishDate.toISOString().slice(0, 10)}
                        &nbsp;·&nbsp;{estimateReadTime(post.body)}&nbsp;MIN READ
                      </p>
                      <h3>{post.data.title}</h3>
                      <p>{post.data.description}</p>
                      <div class="intel-tag-row">
                        {(post.data.tags ?? []).slice(0, 2).map((tag) => (
                          <span class="tag-chip">{tag}</span>
                        ))}
                      </div>
                    </a>
                  ))
                )
              }
            </div>
          </div>
        </div>
      </section>

    </div><!-- /.mono-track -->

    <!-- Panel dots navigation -->
    <nav class="panel-dots" aria-label="Panel navigation">
      <button class="dot is-active" data-panel="0" aria-label="Panel 1: Hero"       type="button"></button>
      <button class="dot"           data-panel="1" aria-label="Panel 2: Philosophy" type="button"></button>
      <button class="dot"           data-panel="2" aria-label="Panel 3: Intel"      type="button"></button>
    </nav>

  </div><!-- /.mono-wrapper -->

  <!-- ═══════════════════════════════════════════════════════════════
       VERTICAL SECTIONS — after the pinned horizontal block
       ═══════════════════════════════════════════════════════════════ -->
  <main class="container site-shell">

    {feedPosts.length > 0 && (
      <>
        <section class="feed-head fade-in fade-delay-1">
          <h2>More from the Feed</h2>
          <p class="post-meta">Architecture notes, operational playbooks, and AI strategy essays.</p>
        </section>
        <section class="feed-grid fade-in fade-delay-2">
          {feedPosts.map((post) => (
            <article class="post-card">
              <a class="post-card-link" href={`/posts/${post.id.replace(/\.md$/, '')}/`}>
                <div class="post-thumb" aria-hidden="true"></div>
                <div class="post-content">
                  <div class="tag-row">
                    {(post.data.tags ?? []).slice(0, 3).map((tag) => (
                      <span class="tag-chip">{tag}</span>
                    ))}
                  </div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <p class="post-meta">
                    {post.data.publishDate.toISOString().slice(0, 10)}
                    &nbsp;·&nbsp;{estimateReadTime(post.body)} min read
                  </p>
                </div>
              </a>
            </article>
          ))}
        </section>
      </>
    )}

    <section id="about" class="about-panel fade-in fade-delay-2">
      <h2>About the Lab</h2>
      <p>
        Nordic minimalism meets American directness. The <strong>◐</strong> icon
        in the top-right cycles three curated Lab themes — Fjord, Foundry, and
        Midnight — each tuned for a different reading context. Every post runs
        through a 19-agent editorial workflow before publication: research,
        fact-checking, voice editing, and risk review.
      </p>
    </section>

  </main>

  <!-- ── GSAP horizontal scroll init — home page only ─────────────── -->
  <script>
    import { initMonolithScroll } from '../scripts/gsap-horizontal-monolith';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    initMonolithScroll();

    // Dot nav: click → scroll to that panel
    const dots    = Array.from(document.querySelectorAll<HTMLButtonElement>('.dot'));
    const panels  = Array.from(document.querySelectorAll<HTMLElement>('[data-mono-panel]'));
    const wrapper = document.querySelector<HTMLElement>('[data-mono-wrapper]');
    const track   = document.querySelector<HTMLElement>('[data-mono-track]');

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        if (!wrapper || !track || panels.length < 2) return;
        const idx         = Number(dot.dataset.panel);
        const scrollWidth = track.scrollWidth - window.innerWidth;
        const step        = scrollWidth / (panels.length - 1);
        window.scrollTo({ top: wrapper.offsetTop + idx * step, behavior: 'smooth' });
      });
    });

    // Keep dots active state in sync while scrubbing
    ScrollTrigger.addEventListener('scrollEnd', () => {
      const st = ScrollTrigger.getById('mono-h-scroll');
      if (!st) return;
      const active = Math.round(st.progress * (panels.length - 1));
      dots.forEach((d, i) => d.classList.toggle('is-active', i === active));
    });
  </script>

</BaseLayout>
