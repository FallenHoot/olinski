---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Olinske by Zach Olinske. Signal Over Hype for enterprise AI, cloud resilience, and CTO operating models.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script>
      const saved = localStorage.getItem('theme') || 'executive';
      const url = new URL(window.location);
      const param = url.searchParams.get('theme');
      const theme = param && ['executive', 'operator', 'horizon'].includes(param) ? param : saved;
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
